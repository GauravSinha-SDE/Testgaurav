CREATE OR REPLACE VIEW SC_LOG.REPORTING_WMS.V_TD_GBL_SC_WMS_INVENTORY_ACCURACY(
    WAREHOUSE_ID            COMMENT 'Warehouse ID',
    YEAR                    COMMENT 'Year',
    TIMESTAMP               COMMENT 'Formatted Timestamp (YYYY-MM-DD)',
    INVENTORY_DOCUMENT      COMMENT 'Inventory Document GUID',
    UNIT                    COMMENT 'Warehouse Unit',
    MATERIAL_NUMBER         COMMENT 'Material Number',
    PRICE_CONTROL_INDICATOR COMMENT 'Price Control Indicator',
    MOVING_AVERAGE_PRICE    COMMENT 'Moving Average Price',
    STANDARD_PRICE          COMMENT 'Standard Price',
    PRICE_UNIT              COMMENT 'Price Unit',
    CURRENCY_KEY            COMMENT 'Currency Key',
    TOTAL_DIFFERENCE        COMMENT 'Total Difference For ITEM_TYPE DI Or PR',
    TOTAL_BOOKED_NUMBER     COMMENT 'Total Booked Number For ITEM_TYPE BO',
    TOTAL_SUM_BOOKED_NUMBER COMMENT 'Total Sum For Booked Number For ITEM_TYPE BO',
    TOTAL_COUNTED_NUMBER    COMMENT 'Total Counted Number For ITEM_TYPE CO Or MU',
    DIFFERENCE_PERCENTAGE   COMMENT 'Percentage Based On DIFF Vs BOOK',
    CC_SOURCE_SYSTEM        COMMENT 'Source System',
    CC_TIMEZONE             COMMENT 'Time Zone'
) COMMENT = 'This View Provides Inventory Accuracy Metrics Based On Document And Quantity Data'
AS
SELECT
    WAREHOUSE_ID,
    YEAR,
    TIMESTAMP,
    INVENTORY_DOCUMENT,
    UNIT,
    MATERIAL_NUMBER,
    PRICE_CONTROL_INDICATOR,
    MAX(MOVING_AVERAGE_PRICE)       AS MOVING_AVERAGE_PRICE,
    MAX(STANDARD_PRICE)             AS STANDARD_PRICE,
    PRICE_UNIT,
    CURRENCY_KEY,
    SUM(TOTAL_DIFFERENCE)           AS TOTAL_DIFFERENCE,
    SUM(TOTAL_BOOKED_NUMBER)        AS TOTAL_BOOKED_NUMBER,
    SUM(TOTAL_SUM_BOOKED_NUMBER)    AS TOTAL_SUM_BOOKED_NUMBER,
    SUM(TOTAL_COUNTED_NUMBER)       AS TOTAL_COUNTED_NUMBER,
    -- AVG of per-line DIFFERENCE_PERCENTAGE (already capped at line level), matching view 3 exactly
    AVG(DIFFERENCE_PERCENTAGE)      AS DIFFERENCE_PERCENTAGE,
    CC_SOURCE_SYSTEM,
    CC_TIMEZONE
FROM (
    -- Middle block: per-line DIFFERENCE_PERCENTAGE calculated and capped here (view 1 grain)
    SELECT
        d.WAREHOUSE_ID,
        d.YEAR,
        d._TIMESTAMP                        AS TIMESTAMP,
        dq.INVENTORY_DOCUMENT,
        dq.ITEM,
        dq.LINE_ROW_INDEX                   AS LINE,
        dq.INVENTORY_UNIT_OF_MEASURE        AS UNIT,
        dq.MATERIAL_NUMBER,
        vl.PRICE_CONTROL_INDICATOR,
        vl.MOVING_AVERAGE_PRICE,
        vl.STANDARD_PRICE,
        vl.PRICE_UNIT,
        vl.CURRENCY_KEY,
        SUM(CASE WHEN dq.STATUS_OF_TABLE_ENTRY = 'DI'
            THEN dq.INVENTORY_QUANTITY ELSE 0 END)              AS TOTAL_DIFFERENCE1,
        SUM(CASE WHEN dq.STATUS_OF_TABLE_ENTRY = 'BO'
            THEN dq.INVENTORY_QUANTITY ELSE 0 END)              AS TOTAL_BOOKED_NUMBER,
        SUM(CASE WHEN dq.STATUS_OF_TABLE_ENTRY IN ('BO', 'PR')
            THEN dq.INVENTORY_QUANTITY ELSE 0 END)              AS TOTAL_SUM_BOOKED_NUMBER,
        SUM(CASE WHEN dq.STATUS_OF_TABLE_ENTRY IN ('CO', 'MU')
            THEN dq.INVENTORY_QUANTITY ELSE 0 END)              AS TOTAL_COUNTED_NUMBER,
        CASE
            WHEN TOTAL_BOOKED_NUMBER = 0
              OR TOTAL_BOOKED_NUMBER < TOTAL_COUNTED_NUMBER
            THEN  TOTAL_DIFFERENCE1
            ELSE -TOTAL_DIFFERENCE1
        END                                                     AS TOTAL_DIFFERENCE,
        -- Per-line percentage capped exactly as view 1 did it
        LEAST(
            GREATEST(
                ROUND(
                    (1 - ABS(DIV0NULL(
                        CASE
                            WHEN TOTAL_BOOKED_NUMBER = 0
                              OR TOTAL_BOOKED_NUMBER < TOTAL_COUNTED_NUMBER
                            THEN  TOTAL_DIFFERENCE1
                            ELSE -TOTAL_DIFFERENCE1
                        END,
                        TOTAL_COUNTED_NUMBER
                    ))) * 100,
                    2
                ),
                -100
            ),
            100
        )                                                       AS DIFFERENCE_PERCENTAGE,
        dq.CC_SOURCE_SYSTEM,
        dq.CC_TIMEZONE
    FROM SC_LOG.INT_UDM_WMS.V_TD_GBL_SC_WMS_INVENTORY_DOCUMENTS_QUANTITIES dq
    LEFT JOIN (
        SELECT DISTINCT
            WAREHOUSE_ID,
            YEAR,
            INVENTORY_DOCUMENT,
            ITEM,
            TO_DATE(SUBSTR(TO_CHAR(TIMESTAMP), 1, 8), 'YYYYMMDD') AS _TIMESTAMP
        FROM SC_LOG.INT_UDM_WMS.V_TD_GBL_SC_WMS_INVENTORY_DOCUMENTS
    ) d
        ON  d.INVENTORY_DOCUMENT = dq.INVENTORY_DOCUMENT
        AND d.ITEM               = dq.ITEM
    LEFT JOIN SC_LOG.INT_UDM_WMS.V_TD_GBL_SC_WMS_INVENTORY_VALUATION vl
        ON  d.WAREHOUSE_ID = vl.WAREHOUSE_ID
        AND dq.MATERIAL_ID = vl.MATERIAL_ID
    WHERE dq.STATUS_OF_TABLE_ENTRY IN ('BO', 'DI', 'PR', 'CO', 'MU')
    GROUP BY ALL
)
GROUP BY ALL;
