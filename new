create or replace view SC_LOG.INT_TMS.V_TD_NA_SC_TMS_EDI_AA(
	TENDER_REQUEST_KEY COMMENT 'Tender Request Key',
	TENDER_REQUEST_ID COMMENT 'Tender Request ID',
	LOAD_LEG_KEY COMMENT 'Primary Key Identifier For The Load Leg Dimension Table',
	LOAD_LEG_ID COMMENT 'Unique Business Identifier For The Load/Shipment Leg',
	CARRIER_KEY COMMENT 'Foreign Key Reference To Carrier Dimension Table',
	CARRIER_CODE COMMENT 'Carrier Code From Carrier Dimension Table',
	MASTER_SERVICE_KEY COMMENT 'Foreign Key Reference To Service Type Dimension Table',
	SERVICE_CODE COMMENT 'Service Code From Service Type Dimension Table',
	TENDER_CREATED_DATE_TIME COMMENT 'Date And Time When The Tender Request Was Initially Created',
	TENDER_START_DATE_TIME COMMENT 'Date And Time When The Tender Process Officially Started',
	TENDER_ACCEPT_DATE COMMENT 'Date And Time When Carrier Accepted The Tender',
	APPOINTMENT_RECEIVED_DATE COMMENT 'Date And Time When Appointment Request Was Received From Carrier',
	CONFIRMED_APPOINTMENT_DATE COMMENT 'Date And Time When Appointment Was Confirmed By All Parties',
	REASON_CODE COMMENT 'Reason Code',
	REASON_CODE_DESCRIPTION COMMENT 'Description Of Reason Code',
	DESTINATION_LOCATION_APPOINTMENT_FLAG COMMENT 'Indicator If Appointment As Required At Destination Location',
	CURRENT_OPERATIONAL_STATUS COMMENT 'Current Operational Status Id Of The Load Leg',
	CURRENT_STATUS_DESCRIPTION COMMENT 'Current Status Description',
	FIRST_SHIPPING_LOCATION_KEY COMMENT 'Foreign Key To First/Origin Shipping Location Dimension',
	FIRST_SHIPPING_LOCATION_CODE COMMENT 'Business Code For The First/Origin Shipping Location',
	FIRST_SHIPPING_LOCATION_NAME COMMENT 'Business Name For The First/Origin Shipping Location',
	FIRST_CITY_STATE COMMENT 'Business Name For The First/Origin Shipping City Name And State Code',
	LAST_SHIPPING_LOCATION_KEY COMMENT 'Business Key For The Final/Destination Shipping Location',
	LAST_SHIPPING_LOCATION_CODE COMMENT 'Business Code For The Final/Destination Shipping Location',
	LAST_SHIPPING_LOCATION_NAME COMMENT 'Business Name For The Final/Destination Shipping Location',
	LAST_CITY_STATE COMMENT 'Business Name For The Final/Destination Shipping City Name And State Code',
	CUSTOMER_HIERARCHY COMMENT 'Customer Hierarchy Classification Or Grouping',
	TEAM_GROUP COMMENT 'Operational Team Or Group Responsible For The Load',
	CC_SOURCE_SYSTEM COMMENT 'Source System',
	AUDIT_TIMEZONE COMMENT 'UCLF Process Time Zone'
) COMMENT='EDIAA View'
 as
( 
 WITH STP_APT AS (SELECT CURRENT_STATUS_DESCRIPTION,SEQUENCE_NUMBER,LOAD_LEG_KEY,SHIPPING_LOCATION_KEY,APT.APPOINTMENT_KEY AS APPOINTMENT_KEY, ROW_NUMBER() OVER (PARTITION BY STP.load_leg_key,STP.sequence_number ORDER BY APT.CC_UPDATED_DATETIMESTAMP DESC)RN FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_STOP STP
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_APPOINTMENT APT
ON STP.APPOINTMENT_KEY = APT.APPOINTMENT_KEY
QUALIFY RN=1),
CTE_TRNS AS
(
SELECT DISTINCT 
        TND.TENDER_REQUEST_KEY,
	TND.TENDER_REQUEST_ID,
        LD.LOAD_LEG_KEY AS LOAD_LEG_KEY, 
        LD.LOAD_LEG_ID AS LOAD_LEG_ID,
        LD.CARRIER_KEY AS CARRIER_KEY,
	CAR.CARRIER_ID AS CARRIER_CODE,
        LD.MASTER_SERVICE_KEY AS MASTER_SERVICE_KEY,  
	SE.SERVICE_CODE AS SERVICE_CODE,      
        TND.CREATED_DATE_TIME AS TENDER_CREATED_DATE_TIME,
        TND.START_DATE_TIME AS TENDER_START_DATE_TIME,
        AU.TENDER_ACCEPT_DATE AS TENDER_ACCEPT_DATE,
        AU2.APPOINTMENT_RECEIVED_DATE AS APPOINTMENT_RECEIVED_DATE,
        APTT.CONFIRMED_APPOINTMENT_DATE AS CONFIRMED_APPOINTMENT_DATE,
        AU2.REASON_CODE AS REASON_CODE, 
        RD.TM_DESC AS REASON_CODE_DESCRIPTION,
        SH.SPFM_APT_RQRD_YN AS APPOINTMENT_REQUIRED,
        LD.CURRENT_OPERATIONAL_STATUS_DESCRIPTION AS CURRENT_OPERATIONAL_STATUS,
        STP_APT.CURRENT_STATUS_DESCRIPTION AS CURRENT_STATUS_DESCRIPTION,
        LD.ORIGIN_SHIPPING_LOCATION_KEY AS FIRST_SHIPPING_LOCATION_KEY,
        LD.FIRST_SHIPPING_LOCATION_CODE AS FIRST_SHIPPING_LOCATION_CODE,
	ORG.SHIPPING_LOCATION_NAME AS FIRST_SHIPPING_LOCATION_NAME,
	CONCAT(LD.EXTENDED_ATTRIBUTES_TMS:FIRST_CITY_NAME, ', ', LD.EXTENDED_ATTRIBUTES_TMS:FIRST_STATE_CODE) AS FIRST_CITY_STATE,
        LD.DESTINATION_SHIPPING_LOCATION_KEY AS LAST_SHIPPING_LOCATION_KEY,
        LD.LAST_SHIPPING_LOCATION_CODE AS LAST_SHIPPING_LOCATION_CODE,
	DEST.SHIPPING_LOCATION_NAME AS LAST_SHIPPING_LOCATION_NAME,
	CONCAT(LD.EXTENDED_ATTRIBUTES_TMS:LAST_CITY_NAME, ', ', LD.EXTENDED_ATTRIBUTES_TMS:LAST_STATE_CODE) AS LAST_CITY_STATE,
        AU2.REASON_CODE_2DIGITS AS REASON_CODE_2DIGITS,        
        STP_APT.SEQUENCE_NUMBER AS STOP_NUMBER,       
        SUBSTR(TRIM(LD.EXTENDED_ATTRIBUTES_TMS:LAST_EVENT_REASON_CODE,'"'),2) AS LAST_EVENT_REASON_CODE,
        RD.TM_REASON_CODE AS TM_REASON_CODE
FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT LD
LEFT JOIN TMS.STAGING.BY_SHPM_T SH ON SH.LD_LEG_ID = LD.LOAD_LEG_ID 
LEFT JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_TENDER_REQUEST TND ON LD.EXTENDED_ATTRIBUTES_TMS:TENDER_REQUEST_ID = TND.TENDER_REQUEST_ID
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_CARRIER CAR ON TND.CARRIER_KEY=CAR.CARRIER_KEY -- To Fetch Carrier Columns
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SERVICE SE ON TND.MASTER_SERVICE_KEY=SE.MASTER_SERVICE_KEY   -- To Fetch Service Columns
LEFT JOIN STP_APT ON LD.LOAD_LEG_KEY = STP_APT.LOAD_LEG_KEY 
AND LD.ORIGIN_SHIPPING_LOCATION_KEY = STP_APT.SHIPPING_LOCATION_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SHIPPING_LOCATION DEST ON  LD.DESTINATION_SHIPPING_LOCATION_KEY = DEST.SHIPPING_LOCATION_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_SHIPPING_LOCATION ORG ON  LD.ORIGIN_SHIPPING_LOCATION_KEY = ORG.SHIPPING_LOCATION_KEY
LEFT JOIN (
            SELECT AU.LOAD_LEG_KEY AS LOAD_LEG_KEY,MIN (AU.EVENT_REPORTED_DATE_TIME) AS TENDER_ACCEPT_DATE
            FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_AUDIT AU
            WHERE AU.DIVISION_KEY = 432541001451559896  -- for KCNA
            AND UPPER (AU.OPERATIONAL_STATUS_DESCRIPTION) = 'TENDER ACCEPTED'
            AND TRIM (AU.EXTENDED_ATTRIBUTES_TMS:AUDIT_CONFIGURATION_CODE,'"') = 'TENDACC'
            GROUP BY AU.LOAD_LEG_KEY
) AU /*As Per Business Logic*/
    ON LD.LOAD_LEG_KEY = AU.LOAD_LEG_KEY
LEFT JOIN (
            SELECT AU2.LOAD_LEG_KEY AS LOAD_LEG_KEY,MIN (AU2.EVENT_REASON_CODE) AS REASON_CODE,
            SUBSTR(MIN (AU2.EVENT_REASON_CODE), -2) AS REASON_CODE_2DIGITS,
            MIN (AU2.AUDIT_SYSTEM_DATE_TIME) AS APPOINTMENT_RECEIVED_DATE
            FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_AUDIT AU2 
            WHERE AU2.DIVISION_KEY = 432541001451559896 --for KCNA
            AND AU2.EVENT_REASON_CODE LIKE 'AA%'
            AND UPPER (AU2.AUDIT_USER_CODE) IN ('EDIIN','KIM_USR_API')
            GROUP BY AU2.LOAD_LEG_KEY
) AU2 /*As Per Business Logic*/
    ON LD.LOAD_LEG_KEY = AU2.LOAD_LEG_KEY
LEFT JOIN (
            SELECT APTT.APPOINTMENT_KEY AS APPOINTMENT_KEY,MIN (APTT.REPORTED_DATE_TIME) AS CONFIRMED_APPOINTMENT_DATE
            FROM SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_APT_ST_TRANSITION APTT
            WHERE PREVIOUS_STATUS_ID = 615
            GROUP BY APTT.APPOINTMENT_KEY
) APTT /*As Per Business Logic*/
    ON STP_APT.APPOINTMENT_KEY = APTT.APPOINTMENT_KEY
LEFT JOIN TMS.STAGING.ABPP_REASON_CODE_SCORE RD 
ON RD.REASON_CODE = COALESCE(AU2.REASON_CODE_2DIGITS,SUBSTR(TRIM(LD.EXTENDED_ATTRIBUTES_TMS:LAST_EVENT_REASON_CODE,'"'),2))
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS DESTADD ON LD.DESTINATION_ADDRESS_KEY = DESTADD.ADDRESS_KEY 
WHERE LD.DIVISION_KEY = 432541001451559896 --for KCNA
AND LD.EXTENDED_ATTRIBUTES_TMS:LAST_COUNTRY_CODE IN ('USA','CAN')
AND LD.TRAILER_EQUIPMENT_TYPE NOT IN ('LTL','PKG')
AND SUBSTR(LD.LAST_SHIPPING_LOCATION_CODE,1,1) IN ('5','9')
AND TRIM(DEST.EXTENDED_ATTRIBUTES_TMS:EXTERNAL_CODE_2,'"') ='CARRIER CALL'
AND CONVERT_TIMEZONE('America/Los_Angeles','UTC',LD.CC_UPDATED_DATETIMESTAMP) > COALESCE((SELECT DATEADD(HOUR, -2,LAST_SUCCESSFUL_LOAD_DATETIME) AS LAST_SUCCESSFUL_LOAD_DATETIME FROM UCMF.UTILITIES.DATA_LOAD_CONFIG_V2 WHERE TARGET_TABLE_ID=(SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2 WHERE TABLE_NAME='SC_LOG.INT_TMS.T_TD_GBL_SC_TMS_EDI_AA')
AND SOURCE_KEY =(SELECT SOURCE_KEY FROM UCMF.UTILITIES.DATA_SOURCE_V2 WHERE SOURCE_NAME='BY_TMS')
AND SOURCE_TABLE_ID = (SELECT TABLE_ID FROM UCMF.UTILITIES.SOURCE_TABLE_VIEW_V2 WHERE TABLE_NAME='SC_LOG.INT_TMS.V_TD_NA_SC_TMS_EDI_AA')), '1901-01-01')
),
/*This Query To Filter Out The Data Based On Given Business Condition*/
CTE_TRNS_SEL1
AS
(
SELECT DISTINCT 
        TENDER_REQUEST_KEY,
	TENDER_REQUEST_ID,
        LOAD_LEG_KEY,
        LOAD_LEG_ID,
        CARRIER_KEY,
	CARRIER_CODE,
        MASTER_SERVICE_KEY,
	SERVICE_CODE,
        TENDER_CREATED_DATE_TIME,
        TENDER_START_DATE_TIME,
        TENDER_ACCEPT_DATE,
        APPOINTMENT_RECEIVED_DATE,
        CONFIRMED_APPOINTMENT_DATE,
        REASON_CODE,
        REASON_CODE_DESCRIPTION,
        APPOINTMENT_REQUIRED,
        CURRENT_OPERATIONAL_STATUS,
        CURRENT_STATUS_DESCRIPTION,
        FIRST_SHIPPING_LOCATION_KEY,
        FIRST_SHIPPING_LOCATION_CODE,
	FIRST_SHIPPING_LOCATION_NAME,
	FIRST_CITY_STATE,
        LAST_SHIPPING_LOCATION_KEY,
        LAST_SHIPPING_LOCATION_CODE,
	LAST_SHIPPING_LOCATION_NAME,
	LAST_CITY_STATE
       
FROM CTE_TRNS
WHERE UPPER(CURRENT_STATUS_DESCRIPTION) = 'CONFIRMED' -- For Id: 615
AND STOP_NUMBER = 1
AND TM_REASON_CODE LIKE 'P%'
),
/*This Query To Filter Out The Data Based On Given Business Condition*/
CTE_TRNS_SEL2
AS
(
SELECT DISTINCT 
        TENDER_REQUEST_KEY,
	TENDER_REQUEST_ID,
        LOAD_LEG_KEY,
        LOAD_LEG_ID,
        CARRIER_KEY,
	CARRIER_CODE,
        MASTER_SERVICE_KEY,
	SERVICE_CODE,
        TENDER_CREATED_DATE_TIME,
        TENDER_START_DATE_TIME,
        TENDER_ACCEPT_DATE,
        APPOINTMENT_RECEIVED_DATE,
        CONFIRMED_APPOINTMENT_DATE,
        REASON_CODE,
        REASON_CODE_DESCRIPTION,
        APPOINTMENT_REQUIRED,
        CURRENT_OPERATIONAL_STATUS,
        CURRENT_STATUS_DESCRIPTION,
        FIRST_SHIPPING_LOCATION_KEY,
        FIRST_SHIPPING_LOCATION_CODE,
	FIRST_SHIPPING_LOCATION_NAME,
	FIRST_CITY_STATE,
        LAST_SHIPPING_LOCATION_KEY,
        LAST_SHIPPING_LOCATION_CODE,
	LAST_SHIPPING_LOCATION_NAME,
	LAST_CITY_STATE
FROM CTE_TRNS  
WHERE (UPPER(CURRENT_STATUS_DESCRIPTION) != 'CONFIRMED' OR CURRENT_STATUS_DESCRIPTION IS NULL)
AND LAST_EVENT_REASON_CODE NOT LIKE 'AA%'
AND STOP_NUMBER = 1
AND TM_REASON_CODE LIKE 'P%'
AND LOAD_LEG_KEY IN (SELECT AU.LOAD_LEG_KEY AS LOAD_LEG_KEY
                    FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_AUDIT AU
                    WHERE AU.DIVISION_KEY = 432541001451559896 --for KCNA
                    AND AU.EVENT_REASON_CODE LIKE 'AA%'
                    AND UPPER (AU.AUDIT_USER_CODE) IN ('EDIIN','KIM_USR_API')
                    )
),
/*This Query To Filter Out The Data Based On Given Business Condition*/
CTE_TRNS_SEL3
AS
(
SELECT DISTINCT 
        TENDER_REQUEST_KEY,
	TENDER_REQUEST_ID,
        LOAD_LEG_KEY,
        LOAD_LEG_ID,
        CARRIER_KEY,
	CARRIER_CODE,
        MASTER_SERVICE_KEY,
	SERVICE_CODE,
        TENDER_CREATED_DATE_TIME,
        TENDER_START_DATE_TIME,
        TENDER_ACCEPT_DATE,
        APPOINTMENT_RECEIVED_DATE,
        CONFIRMED_APPOINTMENT_DATE,
        REASON_CODE,
        REASON_CODE_DESCRIPTION,
        APPOINTMENT_REQUIRED,
        CURRENT_OPERATIONAL_STATUS,
        CURRENT_STATUS_DESCRIPTION,
        FIRST_SHIPPING_LOCATION_KEY,
        FIRST_SHIPPING_LOCATION_CODE,
	FIRST_SHIPPING_LOCATION_NAME,
	FIRST_CITY_STATE,
        LAST_SHIPPING_LOCATION_KEY,
        LAST_SHIPPING_LOCATION_CODE,
	LAST_SHIPPING_LOCATION_NAME,
	LAST_CITY_STATE
FROM CTE_TRNS
WHERE (UPPER(CURRENT_STATUS_DESCRIPTION) != 'CONFIRMED' OR CURRENT_STATUS_DESCRIPTION IS NULL)
AND LAST_EVENT_REASON_CODE NOT LIKE 'AA%'
AND STOP_NUMBER = 1
AND TM_REASON_CODE LIKE 'P%'
AND LOAD_LEG_KEY NOT IN (SELECT AU.LOAD_LEG_KEY AS LOAD_LEG_KEY
                    FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_AUDIT AU
                    WHERE AU.DIVISION_KEY = 432541001451559896 --for KCNA
                    AND AU.EVENT_REASON_CODE LIKE 'AA%'
                    AND UPPER (AU.AUDIT_USER_CODE) IN ('EDIIN','KIM_USR_API')
                    )
),
/*This Query To Union All The Above Three Sets Filtered Data*/
CTE_COMB_SEL
AS
(
SELECT * FROM CTE_TRNS_SEL1
UNION ALL
SELECT * FROM CTE_TRNS_SEL2
UNION ALL
SELECT * FROM CTE_TRNS_SEL3
)
SELECT DISTINCT 
        CO.TENDER_REQUEST_KEY,
	CO.TENDER_REQUEST_ID,
        CO.LOAD_LEG_KEY AS LOAD_LEG_KEY,
        CO.LOAD_LEG_ID AS LOAD_LEG_ID,
        CO.CARRIER_KEY AS CARRIER_KEY,
	CO.CARRIER_CODE AS CARRIER_CODE,
        CO.MASTER_SERVICE_KEY AS MASTER_SERVICE_KEY,
	CO.SERVICE_CODE AS SERVICE_CODE,
        CO.TENDER_CREATED_DATE_TIME AS TENDER_CREATED_DATE_TIME ,
        CO.TENDER_START_DATE_TIME AS TENDER_START_DATE_TIME,
        CO.TENDER_ACCEPT_DATE AS TENDER_ACCEPT_DATE,
        CO.APPOINTMENT_RECEIVED_DATE AS APPOINTMENT_RECEIVED_DATE,
        CO.CONFIRMED_APPOINTMENT_DATE AS CONFIRMED_APPOINTMENT_DATE,
        CO.REASON_CODE AS REASON_CODE,
        CO.REASON_CODE_DESCRIPTION AS REASON_CODE_DESCRIPTION,
        CO.APPOINTMENT_REQUIRED AS DESTINATION_LOCATION_APPOINTMENT_FLAG,
        CO.CURRENT_OPERATIONAL_STATUS AS CURRENT_OPERATIONAL_STATUS,
        CO.CURRENT_STATUS_DESCRIPTION AS CURRENT_STATUS_DESCRIPTION,
        CO.FIRST_SHIPPING_LOCATION_KEY AS FIRST_SHIPPING_LOCATION_KEY,
        CO.FIRST_SHIPPING_LOCATION_CODE AS FIRST_SHIPPING_LOCATION_CODE,
	CO.FIRST_SHIPPING_LOCATION_NAME AS FIRST_SHIPPING_LOCATION_NAME,
	CO.FIRST_CITY_STATE AS FIRST_CITY_STATE,
        CO.LAST_SHIPPING_LOCATION_KEY AS LAST_SHIPPING_LOCATION_KEY,
        CO.LAST_SHIPPING_LOCATION_CODE AS LAST_SHIPPING_LOCATION_CODE,
	CO.LAST_SHIPPING_LOCATION_NAME AS LAST_SHIPPING_LOCATION_NAME,
	CO.LAST_CITY_STATE AS LAST_CITY_STATE,
        CN.CODE_DESCRIPTION AS CUSTOMER_HIERARCHY,
        AN.TEAM_GROUP AS TEAM_GROUP,
        'BY' AS CC_SOURCE_SYSTEM,
        'UTC' AS AUDIT_TIMEZONE
FROM  CTE_COMB_SEL CO
LEFT JOIN  TMS.STAGING.T_GBL_BY_CONFIG_LKP CN
ON CN.CODE_VALUE =  LEFT(CO.LAST_SHIPPING_LOCATION_CODE,8)
LEFT JOIN SC_LOG.INT_TMS.V_MD_NA_SC_TMS_ANALYST_ASSIGNMENT AN
ON AN.LOCATION_ID = FIRST_SHIPPING_LOCATION_CODE AND AN.ACTIVE = 'TRUE'
AND  CAST(AN.TO_DATE AS DATE) >= CAST(GETDATE() AS DATE)
);
