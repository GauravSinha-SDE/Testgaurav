    ORIGIN_SHIPPING_LOCATION_KEY,
    DESTINATION_SHIPPING_LOCATION_KEY,
    ORIGIN_ADDRESS_KEY,
    DESTINATION_ADDRESS_KEY,
    CARRIER_KEY,
    CUSTOMER_KEY,
    DIVISION_KEY,
    LOAD_LEG_ID,
    LOAD_AT_CORPORATE_ID_1,
    SHIPMENT_TYPE,
