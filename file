    LT.TRAILER_EQUIPMENT_TYPE AS TRAILER_EQUIPMENT_TYPE,
    COALESCE(TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LOAD_AT_CORPORATE_ID_2,'""""'),LT.LOAD_AT_NAME) AS SHIPMENT_FROM_NAME,
    CASE WHEN CUST.CODE_DESCRIPTION IS NOT NULL THEN CUST.CODE_DESCRIPTION
    ELSE
        CASE WHEN substr(LT.LAST_SHIPPING_LOCATION_CODE, 5, 1) = '-'  THEN  'K-C'
             WHEN (substr(LT.LAST_SHIPPING_LOCATION_CODE, 1, 2) = '58') OR (substr(LT.LAST_SHIPPING_LOCATION_CODE, 5, 1) = '99999999') 
                THEN 'OTHER CUSTOMER'
            WHEN (substr(LT.LAST_SHIPPING_LOCATION_CODE, 1, 2) = 'AK') OR (substr(LT.LAST_SHIPPING_LOCATION_CODE, 1, 2) = 'HI' )  OR (substr(LT.LAST_SHIPPING_LOCATION_CODE, 1, 4) = 'LCL-' ) THEN 'HUB'
        ELSE 'UNKNOWN'
