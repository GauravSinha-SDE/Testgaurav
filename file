    FIRST_APPOINTMENT_CONFIRMED,
    FIRST_TENDER_ACCEPTANCE_COUNT,
    ORIGIN_APPOINTMENT_DATETIME,
    ORIGIN_ARRIVAL_DATETIME,
    ORIGIN_DEPARTURE_DATETIME,
    ORIGIN_ARRIVAL_ONTIME_COUNT,
    ORIGIN_ARRIVAL_ONTIME_INDICATOR,
    DESTINATION_APPOINTMENT_DATETIME,
    DESTINATION_ARRIVAL_DATETIME,
    DESTINATION_DEPARTURE_DATETIME,
    DESTINATION_ARRIVAL_ONTIME_COUNT,
