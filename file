    TT.CARR_ARRIVED_AT_DATETIME AS CARR_ARRIVED_AT_DATETIME,    
    TT.DESTINATION_ARRIVAL_DATETIME AS ACTUAL_DELIVERY_DATE,  
    TT.EARLY_STOP_INDICATOR AS CAPS_EARLY_STOP_COUNT,
    TT.ONTIME_STOP_INDICATOR AS CAPS_ONTIME_STOP_COUNT,
    TT.LATE_STOP_INDICATOR  AS CAPS_LATE_STOP_COUNT,
    TT.SHIPMENT_NUMBER AS CAPS_DELIVERED_STOP_COUNT,
    TT.DESTINATION_ARRIVAL_ONTIME_STOP_INDICATOR AS DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,
    CASE WHEN LTD.SHPM_REFERENCE_NUMBER_22 = 'Z05' 
                THEN 'NON WOVENS' 
        WHEN LT.LOAD_AT_CORPORATE_ID_1 = 'RM'
                THEN 'RM-INBOUND'
         WHEN LT.LOAD_AT_CORPORATE_ID_1 = 'RF'
                THEN 'RF-INBOUND'
         WHEN substring(LT.LAST_SHIPPING_LOCATION_CODE,1,1) = 'R' 
                THEN 'RETURNS'
         WHEN (substring(LT.LAST_SHIPPING_LOCATION_CODE,1,1) = '1' OR substring(LT.LAST_SHIPPING_LOCATION_CODE,1,1) = '2') 
                THEN 'INTERMILL'
         WHEN (substring(LT.LAST_SHIPPING_LOCATION_CODE,1,1) = '5' OR substring(LT.LAST_SHIPPING_LOCATION_CODE,1,1) = '9' )
