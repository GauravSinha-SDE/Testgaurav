/*To get the distinct records based on stop_count*/
CTE_STOP_CAL
AS
(
SELECT 
    LOAD_LEG_KEY,
    LOAD_LEG_ID,
    STOP_COUNT,
    ORIGIN_ARRIVAL_ONTIME,
    DESTINATION_ARRIVAL_ONTIME,
    CAPS_EARLY_STOP_COUNT,
    CAPS_ONTIME_STOP_COUNT, 
    CAPS_LATE_STOP_COUNT,
    DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,
    CAPS_DELIVERED_STOP_COUNT,
    RNK,
    CSRS_EARLY_STOP_COUNT,CSRS_ONTIME_STOP_COUNT,CSRS_LATE_STOP_COUNT,CSRS_DELIVERED_STOP_COUNT,STOP_RESPONSE_COUNT
FROM 
(
    SELECT LOAD_LEG_KEY,LOAD_LEG_ID,STOP_COUNT,ORIGIN_ARRIVAL_ONTIME,DESTINATION_ARRIVAL_ONTIME,CAPS_EARLY_STOP_COUNT, 
    CAPS_ONTIME_STOP_COUNT,CAPS_LATE_STOP_COUNT,DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,CAPS_DELIVERED_STOP_COUNT,
    DENSE_RANK() OVER (PARTITION BY LOAD_LEG_ID,STOP_COUNT ORDER BY CAPS_DELIVERED_STOP_COUNT) AS RNK,
    CSRS_EARLY_STOP_COUNT,CSRS_ONTIME_STOP_COUNT,CSRS_LATE_STOP_COUNT,CSRS_DELIVERED_STOP_COUNT,STOP_RESPONSE_COUNT
    FROM CTE_COL_SELECT
)
WHERE RNK = 1  
),-- select * from CTE_STOP_CAL;,
/*To get the count of stop,delivered stop,arrival,early,late,ontime stops*/
CTE_STOP_CNT
AS
(
SELECT LOAD_LEG_KEY,LOAD_LEG_ID,SUM(DISTINCT STOP_COUNT) AS STOP_COUNT_CNT,SUM(DISTINCT CAPS_DELIVERED_STOP_COUNT) AS CAPS_DELIVERED_STOP_CNT,
    ORIGIN_ARRIVAL_ONTIME_INDICATOR,
    SUM(DISTINCT ORIGIN_ARRIVAL_ONTIME_COUNT) AS ORIGIN_ARRIVAL_ONTIME_COUNT,
    SUM(DISTINCT DESTINATION_ARRIVAL_ONTIME_COUNT) AS DESTINATION_ARRIVAL_ONTIME_COUNT,
    SUM(DISTINCT CAPS_EARLY_STOP_COUNT) AS CAPS_EARLY_STOP_COUNT,
    SUM(DISTINCT CAPS_ONTIME_STOP_COUNT) AS CAPS_ONTIME_STOP_COUNT, 
    SUM(DISTINCT CAPS_LATE_STOP_COUNT) AS CAPS_LATE_STOP_COUNT,
    SUM(DISTINCT DESTINATION_ARRIVAL_ONTIME_STOP_COUNT) AS DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,
    SUM(DISTINCT CSRS_EARLY_STOP_COUNT) AS CSRS_EARLY_STOP_COUNT,
    SUM(DISTINCT CSRS_ONTIME_STOP_COUNT) AS CSRS_ONTIME_STOP_COUNT,
    SUM(DISTINCT CSRS_LATE_STOP_COUNT) AS CSRS_LATE_STOP_COUNT,
    SUM(DISTINCT CSRS_DELIVERED_STOP_COUNT) AS CSRS_DELIVERED_STOP_COUNT,
    SUM(DISTINCT STOP_RESPONSE_COUNT) AS STOP_RESPONSE_COUNT
FROM
(
    SELECT 
        LOAD_LEG_KEY,LOAD_LEG_ID,STOP_COUNT ,CAPS_DELIVERED_STOP_COUNT, ORIGIN_ARRIVAL_ONTIME AS ORIGIN_ARRIVAL_ONTIME_INDICATOR,
        CASE WHEN ORIGIN_ARRIVAL_ONTIME = 'Y' THEN 1 ELSE 0 END AS ORIGIN_ARRIVAL_ONTIME_COUNT,
        CASE WHEN DESTINATION_ARRIVAL_ONTIME = 'Y' THEN 1 ELSE 0 END AS DESTINATION_ARRIVAL_ONTIME_COUNT,
        CASE WHEN CAPS_EARLY_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CAPS_EARLY_STOP_COUNT,
        CASE WHEN CAPS_ONTIME_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CAPS_ONTIME_STOP_COUNT,
        CASE WHEN CAPS_LATE_STOP_COUNT ='TRUE' THEN 1 ELSE 0 END AS CAPS_LATE_STOP_COUNT,
        CASE WHEN DESTINATION_ARRIVAL_ONTIME_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,
        ----------
        CASE WHEN CSRS_EARLY_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CSRS_EARLY_STOP_COUNT,        
        CASE WHEN CSRS_ONTIME_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CSRS_ONTIME_STOP_COUNT, 
        CASE WHEN CSRS_LATE_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CSRS_LATE_STOP_COUNT,
        CASE WHEN CSRS_DELIVERED_STOP_COUNT = 'TRUE' THEN 1 ELSE 0 END AS CSRS_DELIVERED_STOP_COUNT,
        CASE WHEN STOP_RESPONSE_COUNT = 'TRUE' THEN 1 ELSE 0 END AS STOP_RESPONSE_COUNT
    FROM CTE_STOP_CAL 
) GROUP BY LOAD_LEG_KEY,LOAD_LEG_ID,ORIGIN_ARRIVAL_ONTIME_INDICATOR
),-- select * from CTE_STOP_CNT;
/*To get one start and created date from two tender requests for on load leg key   */
CTE_TENDER_SEL
AS
(
SELECT 
    LOAD_LEG_KEY,
    START_DATE_TIME,
    CREATED_DATE_TIME,
    TENDER_REQUEST_ID,
    FIRST_TENDER_ACCEPTANCE_COUNT,
    ROUND((DATE_PART(EPOCH_SECOND,START_DATE_TIME) - DATE_PART(EPOCH_SECOND, CREATED_DATE_TIME)) / 3600.0, 1) AS TENDER_LEAD_HOURS,
    R_NO
FROM 
    (
        SELECT 
            SEL.LOAD_LEG_KEY AS LOAD_LEG_KEY,
            TED.START_DATE_TIME AS START_DATE_TIME,
            TED.CREATED_DATE_TIME AS CREATED_DATE_TIME,
            TED.TENDER_REQUEST_ID AS TENDER_REQUEST_ID,
            CASE WHEN TENDER_RESPONSE_CODE = 'ACPD' THEN 1 ELSE 0  END AS FIRST_TENDER_ACCEPTANCE_COUNT,
            ROW_NUMBER() OVER(PARTITION BY SEL.LOAD_LEG_ID ORDER BY TED.TENDER_REQUEST_ID) AS  R_NO
        FROM CTE_COL_SELECT SEL
        LEFT JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_TENDER_REQUEST TED ON TED.LOAD_LEG_KEY = SEL.LOAD_LEG_KEY AND TED.CARRIER_KEY <> HASH('FRAN','BY')
    ) WHERE R_NO = 1
),--select * from CTE_TENDER_SEL;
CTE_APPOINT_SEL
AS
(
SELECT
    SE.LOAD_LEG_ID,
    SE.LOAD_LEG_KEY,
    SE.ORIGIN_STOP_KEY,
    ST.APPOINTMENT_KEY AS APPOINTMENT_KEY,
    APP.APPOINTMENT_FROM_DATE_TIME AS APPOINTMENT_FROM_DATE_TIME,
    APP.CURRENT_STATUS_DESCRIPTION AS CURRENT_STATUS_DESCRIPTION,
    CASE WHEN APP.CURRENT_STATUS_DESCRIPTION = 'Notified' THEN APP.APPOINTMENT_FROM_DATE_TIME ELSE NULL END AS FIRST_APPOINTMENT_NOTIFIED,
    CASE WHEN APP.CURRENT_STATUS_DESCRIPTION = 'Confirmed' THEN APP.APPOINTMENT_FROM_DATE_TIME ELSE NULL END AS FIRST_APPOINTMENT_CONFIRMED
FROM CTE_COL_SELECT SE
LEFT JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_STOP ST ON ST.STOP_KEY = SE.ORIGIN_STOP_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_APPOINTMENT APP ON APP.APPOINTMENT_KEY = ST.APPOINTMENT_KEY
),
/*This is to get distance for lastest stop id incase multiple sequence =2 exist in UDM STOP table */
CTE_STOP_DIST_SEL
AS
(
SELECT LOAD_LEG_KEY, DISTANCE_FROM_PREVIOUS_STOP
FROM (
    SELECT 
        SE.LOAD_LEG_KEY,
        STP.SEQUENCE_NUMBER, 
        STP.DISTANCE_FROM_PREVIOUS_STOP,
        STP.STOP_ID,
        STP.CC_UPDATED_DATETIMESTAMP,
        ROW_NUMBER() OVER (PARTITION BY STP.LOAD_LEG_KEY, STP.SEQUENCE_NUMBER ORDER BY STP.STOP_ID DESC,STP.CC_UPDATED_DATETIMESTAMP ASC ) AS R_NUM  
    FROM CTE_COL_SELECT SE
    LEFT JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_STOP STP
    ON SE.LOAD_LEG_KEY = STP.LOAD_LEG_KEY
    AND STP.SEQUENCE_NUMBER =2 
) WHERE R_NUM = 1
),
/*To add group by for calculating early, ontime etc. stop counts */
CTE_GET_CNT
AS
(
SELECT 
    SEL.LOAD_LEG_KEY,
    SEL.MASTER_SERVICE_KEY,
    SEL.ORIGIN_SHIPPING_LOCATION_KEY,
    SEL.DESTINATION_SHIPPING_LOCATION_KEY,
    SEL.ORIGIN_ADDRESS_KEY,
    SEL.DESTINATION_ADDRESS_KEY,
    SEL.CARRIER_KEY,
    SEL.CUSTOMER_KEY,
    SEL.DIVISION_KEY,
    SEL.LOAD_LEG_ID,
    LOAD_AT_CORPORATE_ID_1,
    SHIPMENT_TYPE,
    CASE WHEN(SHIPMENT_TYPE = 'RECFIBER' AND LOAD_AT_CORPORATE_ID_1 IS NULL) THEN 'RF' ELSE LOAD_AT_CORPORATE_ID_1 END AS CONSIGNEE_CORPORATE_ID_1,
    BUSINESS_UNIT,
    SALES_ORGANIZATION,
    SEL.TRAILER_EQUIPMENT_TYPE,
    SHIPMENT_FROM_NAME,
    CUSTOMER_TYPE,
    LOAD_STATUS,
    SEL.TOTAL_CHARGE_AMOUNT AS TOTAL_CHARGE_AMOUNT,
    MAX(TRIM(LD.EXTENDED_ATTRIBUTES_TMS:SHIPMENT_ITEM_REFERENCE_NUMBER,'""""')) AS FREIGHT_TYPE,
    REG.REGION_NAME AS REGION_NAME,
    REG.CARRIER_MANAGER AS CARRIER_MANAGER,
    TEAM_NAME,
    TEAM_ID,
    MIN(TEAM_GROUP) AS TEAM_GROUP,
    TED.TENDER_LEAD_HOURS AS TENDER_LEAD_HOURS,
    TED.START_DATE_TIME AS START_DATE_TIME,
    TOTAL_MILES,
    TOTAL_KILOMETERS,
    TED.CREATED_DATE_TIME AS FIRST_TENDER_DATE,
    MIN(AP.FIRST_APPOINTMENT_NOTIFIED) AS FIRST_APPOINTMENT_NOTIFIED,
    MIN(AP.FIRST_APPOINTMENT_CONFIRMED) AS FIRST_APPOINTMENT_CONFIRMED,
    TED.FIRST_TENDER_ACCEPTANCE_COUNT AS FIRST_TENDER_ACCEPTANCE_COUNT,
    MIN(ORIGIN_APPOINTMENT_DATETIME) AS ORIGIN_APPOINTMENT_DATETIME,    
    MIN(ORIGIN_ARRIVAL_DATETIME) AS ORIGIN_ARRIVAL_DATETIME,
    MAX(ORIGIN_DEPARTURE_DATETIME) AS ORIGIN_DEPARTURE_DATETIME ,
    MIN(CAL.ORIGIN_ARRIVAL_ONTIME_COUNT) AS ORIGIN_ARRIVAL_ONTIME_COUNT, 
    MIN(CAL.ORIGIN_ARRIVAL_ONTIME_INDICATOR) AS ORIGIN_ARRIVAL_ONTIME_INDICATOR,
    MIN(DESTINATION_APPOINTMENT_DATETIME) AS DESTINATION_APPOINTMENT_DATETIME,
    MIN(DESTINATION_ARRIVAL_DATETIME) AS DESTINATION_ARRIVAL_DATETIME,
    MAX(DESTINATION_DEPARTURE_DATETIME) AS DESTINATION_DEPARTURE_DATETIME,
    MIN(CAL.DESTINATION_ARRIVAL_ONTIME_COUNT) AS DESTINATION_ARRIVAL_ONTIME_COUNT,
    MAX(LAST_STOP_FINAL_APPOINTMENT_DATETIME) AS LAST_STOP_FINAL_APPOINTMENT_DATETIME,
    MAX(CARR_ARRIVED_AT_DATETIME) AS CARR_ARRIVED_AT_DATETIME,  
    MAX(ACTUAL_DELIVERY_DATE) AS ACTUAL_DELIVERY_DATE ,
    MIN(CAL.CAPS_EARLY_STOP_COUNT) AS CAPS_EARLY_STOP_COUNT,
    MIN(CAL.CAPS_ONTIME_STOP_COUNT) AS CAPS_ONTIME_STOP_COUNT,
    MIN(CAL.CAPS_LATE_STOP_COUNT) AS CAPS_LATE_STOP_COUNT,
    MIN(CAPS_DELIVERED_STOP_CNT) AS CAPS_DELIVERED_STOP_COUNT,
    MIN(CAL.DESTINATION_ARRIVAL_ONTIME_STOP_COUNT) AS DESTINATION_ARRIVAL_ONTIME_STOP_COUNT,
    ORDER_TYPE,
    MIN(STOP_COUNT_CNT) AS STOP_COUNT,
    MAX(DESTINATION_ARRIVAL_DATETIME) AS LAST_DESTINATION_ARRIVAL_DATETIME,
    MAX(DESTINATION_DEPARTURE_DATETIME) AS LAST_DESTINATION_DEPARTURE_DATETIME,
    MAX(LAST_STOP_BASE_APPOINTMENT_DATE_TIME) AS LAST_STOP_BASE_APPOINTMENT_DATE_TIME,
    MAX(LAST_STOP_FINAL_APPOINTMENT_DATE_TIME) AS LAST_STOP_FINAL_APPOINTMENT_DATE_TIME,
    MIN(REASON_GROUP) AS REASON_GROUP,
    MIN(REASON_OWNER) AS REASON_OWNER,
    MIN(CSRS_REASON_DESCRIPTION) AS CSRS_REASON_DESCRIPTION,
    MIN(CAPS_REASON_DESCRIPTION) AS CAPS_REASON_DESCRIPTION,
    ORIGIN_STATUS_CODE,
    DESTINATION_STATUS_CODE,
    MIN(CAL.CSRS_EARLY_STOP_COUNT) AS CSRS_EARLY_STOP_COUNT,
    MIN(CAL.CSRS_ONTIME_STOP_COUNT) AS CSRS_ONTIME_STOP_COUNT,
    MIN(CAL.CSRS_LATE_STOP_COUNT) AS CSRS_LATE_STOP_COUNT,
    MIN(CAL.CSRS_DELIVERED_STOP_COUNT) AS CSRS_DELIVERED_STOP_COUNT,
    MIN(CAL.STOP_RESPONSE_COUNT) AS STOP_RESPONSE_COUNT,
    'KCNA_CARRIER_PORTAL' AS CC_SOURCE_SYSTEM,
    CURRENT_TIMESTAMP() AS CC_CREATED_DATETIMESTAMP,
    CURRENT_TIMESTAMP() AS CC_UPDATED_DATETIMESTAMP,
    'UTC' AS CC_TIMEZONE,
    SEL.SHIPPED_DATE,
    SEL.TM_AUCTION_COUNT,
    SEL.START_DATE,
    SEl.LANE_DESCRIPTION,
    MAX(CASE WHEN TRIM(LD.EXTENDED_ATTRIBUTES_TMS:SHPM_REFERENCE_NUMBER_18,'""""') IN ('ZUSM','ZNSM') THEN 'Y' ELSE 'N' END) AS SPACEMAKER,
    STP.DISTANCE_FROM_PREVIOUS_STOP AS DISTANCE_TO_FIRST_STOP,
    SEL.LT_FIRST_SHIPPING_LOCATION_CODE AS FIRST_SHIPPING_LOCATION_CODE,
    SEL.LT_LAST_SHIPPING_LOCATION_CODE AS LAST_SHIPPING_LOCATION_CODE,
    SEL.FIRST_CITY_NAME,
    SEL.FIRST_STATE_CODE,
    SEL.FIRST_POSTAL_CODE,
    SEL.FIRST_COUNTRY_CODE,
    SEL.LAST_CITY_NAME,
    SEL.LAST_STATE_CODE,
    SEL.LAST_POSTAL_CODE,
    SEL.LAST_COUNTRY_CODE,
    SEL.ORIGINAL_PICKUP_TO_DATETIME,
    SEL.COMPLETION_DATE_TIME,
    SEL.LIVE_LOAD_ID,
    SEL.CREATE_DATE_TIME,
    SEL.END_DATE_TIME,
    SEL.BROKER_FLAG,
    SEL.DEDICATED_CARRIER_FLAG
FROM CTE_COL_SELECT SEL
LEFT JOIN CTE_STOP_CNT CAL
ON SEL.LOAD_LEG_KEY = CAL.LOAD_LEG_KEY
LEFT JOIN CTE_TENDER_SEL TED ON TED.LOAD_LEG_KEY = SEL.LOAD_LEG_KEY
LEFT JOIN CTE_APPOINT_SEL AP ON AP.LOAD_LEG_KEY = SEL.LOAD_LEG_KEY
LEFT JOIN SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_DETAIL LD ON LD.LOAD_LEG_ID = SEL.LOAD_LEG_ID
LEFT JOIN CTAS_REGION REG ON REG.STATE_CD = (CASE  
                                                    WHEN ORDER_TYPE LIKE '%INBOUND%' AND BUSINESS_UNIT <> 'NON WOVENS' 
                                                    THEN DESTINATION_STATUS_CODE 
                                            ELSE ORIGIN_STATUS_CODE END
                                            )
LEFT JOIN CTE_STOP_DIST_SEL STP ON SEL.LOAD_LEG_KEY = STP.LOAD_LEG_KEY
GROUP BY SEL.LOAD_LEG_KEY,SEL.MASTER_SERVICE_KEY,SEL.ORIGIN_SHIPPING_LOCATION_KEY,SEL.DESTINATION_SHIPPING_LOCATION_KEY,SEL.CARRIER_KEY, SEL.CUSTOMER_KEY, SEL.DIVISION_KEY,SEL.ORIGIN_ADDRESS_KEY,SEL.DESTINATION_ADDRESS_KEY,SEL.LOAD_LEG_ID,LOAD_AT_CORPORATE_ID_1,SHIPMENT_TYPE,BUSINESS_UNIT,SALES_ORGANIZATION,SEL.TRAILER_EQUIPMENT_TYPE,SHIPMENT_FROM_NAME,CUSTOMER_TYPE,LOAD_STATUS,SEL.TOTAL_CHARGE_AMOUNT,REGION_NAME,CARRIER_MANAGER,TEAM_NAME,TEAM_ID, TED.TENDER_LEAD_HOURS,TED.START_DATE_TIME,TOTAL_MILES,TOTAL_KILOMETERS,TED.CREATED_DATE_TIME, TED.FIRST_TENDER_ACCEPTANCE_COUNT,CARR_ARRIVED_AT_DATETIME,ORDER_TYPE,ORIGIN_STATUS_CODE, DESTINATION_STATUS_CODE,SEL.SHIPPED_DATE, SEL.TM_AUCTION_COUNT, SEL.START_DATE, SEL.LANE_DESCRIPTION,STP.DISTANCE_FROM_PREVIOUS_STOP,SEL.LT_FIRST_SHIPPING_LOCATION_CODE,    SEL.LT_LAST_SHIPPING_LOCATION_CODE,SEL.FIRST_CITY_NAME,SEL.FIRST_CITY_NAME,SEL.FIRST_STATE_CODE,SEL.FIRST_POSTAL_CODE,SEL.FIRST_COUNTRY_CODE,    SEL.LAST_CITY_NAME,SEL.LAST_STATE_CODE,SEL.LAST_POSTAL_CODE,SEL.LAST_COUNTRY_CODE,SEL.ORIGINAL_PICKUP_TO_DATETIME,SEL.COMPLETION_DATE_TIME,SEL.LIVE_LOAD_ID,    SEL.CREATE_DATE_TIME,SEL.END_DATE_TIME,SEL.BROKER_FLAG,SEL.DEDICATED_CARRIER_FLAG)
SELECT 
    LOAD_LEG_KEY,
