    LT.LOAD_AT_CORPORATE_ID_1 AS LOAD_AT_CORPORATE_ID_1, LT.CONSIGNEE_CORPORATE_ID_1 AS CNSE_CONSIGNEE_CORPORATE_ID_1,
    CASE WHEN LTD.SHPM_REFERENCE_NUMBER_22 ='Z05' THEN 'NON WOVENS'
         WHEN (SUBSTR(LT.FIRST_SHIPPING_LOCATION_CODE,5,1) = '-' AND SUBSTR(LT.LAST_SHIPPING_LOCATION_CODE,5,1) = '-') THEN 'STO'
         WHEN (SUBSTR(LT.FIRST_SHIPPING_LOCATION_CODE,5,1) = '-' AND (SUBSTR(LT.LAST_SHIPPING_LOCATION_CODE,1,1) ='5' OR LT.LAST_SHIPPING_LOCATION_CODE ='99999999')) THEN 'CUSTOMER'
         WHEN (SUBSTR(LT.FIRST_SHIPPING_LOCATION_CODE,1,1) = 'V' AND SUBSTR(LT.LOAD_AT_CORPORATE_ID_1,1,2) = 'RM') THEN 'MATERIALS'
         WHEN (SUBSTR(LT.FIRST_SHIPPING_LOCATION_CODE,1,1) = 'V' AND SUBSTR(LT.LOAD_AT_CORPORATE_ID_1,1,2) = 'RF') THEN 'RECFIBER'
