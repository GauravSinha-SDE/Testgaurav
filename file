    ANL.TEAM_NAME AS TEAM_NAME, 
    ANL.TEAM_ID AS TEAM_ID, 
    ANL.TEAM_GROUP AS TEAM_GROUP,
    (LT.DISTANCE_IN_MILE_TOTAL* 0.621371) AS TOTAL_MILES,
    LT.DISTANCE_IN_MILE_TOTAL AS TOTAL_KILOMETERS,
    TT.ORIGIN_APPOINTMENT_DATETIME AS ORIGIN_APPOINTMENT_DATETIME,    
    TT.ORIGIN_ARRIVAL_DATETIME AS ORIGIN_ARRIVAL_DATETIME,
    TT.ORIGIN_DEPARTURE_DATETIME AS ORIGIN_DEPARTURE_DATETIME,
