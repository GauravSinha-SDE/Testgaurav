   -- ROUND((DATE_PART(EPOCH_SECOND,START_DATE_TIME) - DATE_PART(EPOCH_SECOND, FIRST_TENDER_DATE)) / 3600.0, 1) AS TENDER_LEAD_HOURS,
    TENDER_LEAD_HOURS,
