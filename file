    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_CITY_NAME,'""""') AS LAST_CITY_NAME,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_STATE_CODE,'""""') AS LAST_STATE_CODE,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_POSTAL_CODE,'""""') AS LAST_POSTAL_CODE,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:LAST_COUNTRY_CODE,'""""') AS LAST_COUNTRY_CODE,
    LT.ORIGINAL_PICKUP_TO_DATE_TIME AS ORIGINAL_PICKUP_TO_DATETIME,
    TRIM(COALESCE(TT.EXTENDED_ATTRIBUTES_TMS:ACTUAL_SHIPMENT_COMPLETION_DATE_TIME_ORIGIN_TZ,TT.EXTENDED_ATTRIBUTES_TMS:ORIGIN_ACTUAL_SHIPMENT_COMPLETION_TIME_ZONE),'""""') AS COMPLETION_DATE_TIME,
    TRIM(TT.EXTENDED_ATTRIBUTES_TMS:LIVE_LOAD_FLAG,'""""') AS LIVE_LOAD_ID,
    LT.SHIPMENT_CREATED_DATE_TIME AS  CREATE_DATE_TIME,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:END_DATE_TIME,'""""') AS END_DATE_TIME,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:BROKER_FLAG,'""""') AS BROKER_FLAG,
    TRIM(LT.EXTENDED_ATTRIBUTES_TMS:DEDICATED_CARRIER_FLAG,'""""') AS DEDICATED_CARRIER_FLAG,
	
FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT LT
LEFT JOIN CTE_LTD LTD ON LT.LOAD_LEG_ID = LTD.LOAD_LEG_ID
LEFT JOIN CTE_TRASPORT_TRACKING TT ON TT.LOAD_LEG_ID = LT.LOAD_LEG_ID
LEFT JOIN CTAS_CUST_GRP CUST ON CUST.CODE_VALUE = SUBSTR(LT.LAST_SHIPPING_LOCATION_CODE, 1, 8)
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS ORG ON ORG.ADDRESS_KEY = LT.ORIGIN_ADDRESS_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS DES ON DES.ADDRESS_KEY = LT.DESTINATION_ADDRESS_KEY
LEFT JOIN SC_LOG.INT_TMS.V_MD_NA_SC_TMS_ANALYST_ASSIGNMENT ANL ON ANL.LOCATION_ID = LT.FIRST_SHIPPING_LOCATION_CODE
AND ANL.ACTIVE = 'Y' AND ANL.TO_DATE > CURRENT_DATE()
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS AO ON AO.ADDRESS_KEY = LT.ORIGIN_ADDRESS_KEY
LEFT JOIN SC_MD.INT_SC_MD.T_MD_GBL_SC_TMS_ADDRESS AD ON AD.ADDRESS_KEY = LT.DESTINATION_ADDRESS_KEY
