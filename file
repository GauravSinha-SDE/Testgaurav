    LT.ORIGIN_ADDRESS_KEY AS ORIGIN_ADDRESS_KEY,
    LT.DESTINATION_ADDRESS_KEY AS DESTINATION_ADDRESS_KEY,
    LT.CARRIER_KEY,
    LT.CUSTOMER_KEY,
    LT.DIVISION_KEY,
