(
/*Logic as per BRD doc. To calculate sales orgs corresponding to load_leg_ids*/
WITH CTE_LTD
AS
(
SELECT LOAD_LEG_ID,TRIM(EXTENDED_ATTRIBUTES_TMS:SHPM_REFERENCE_NUMBER_22, '""""') AS SHPM_REFERENCE_NUMBER_22,
ROW_NUMBER() OVER(PARTITION BY LOAD_LEG_ID ORDER BY SUM(BASE_VOLUME) DESC) AS ROW_NBR 
FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_LOAD_TRANSPORT_DETAIL
GROUP BY LOAD_LEG_ID,EXTENDED_ATTRIBUTES_TMS:SHPM_REFERENCE_NUMBER_22
QUALIFY ROW_NBR =1
),
/*Customer grouping CTE as per BRD doc.*/
CTAS_CUST_GRP
AS
(
SELECT CODE_VALUE,
       CODE_DESCRIPTION 
FROM TMS.STAGING.T_GBL_BY_CONFIG_LKP WHERE
GROUP_DESCRIPTION = 'CUSTOMER_GROUPINGS'
AND COLUMN_NAME = 'HIERARCHY'
),
CTAS_REGION
AS
(
SELECT CODE_VALUE AS STATE_CD,
        CODE_DESCRIPTION AS REGION_NAME,
        COLUMN_COMMENT AS CARRIER_MANAGER 
FROM TMS.STAGING.T_GBL_BY_CONFIG_LKP WHERE COLUMN_NAME = 'STATE' AND CC_SOURCE_SYSTEM = 'BY_KCNA'
),
/*CTE to get the calculated attributes as per logic provided in BRD doc.*/
CTE_COL_SELECT
AS
( WITH CTE_TRASPORT_TRACKING AS (SELECT *,DENSE_RANK()OVER (PARTITION BY LOAD_LEG_ID ORDER BY CC_UPDATED_DATETIMESTAMP DESC) AS RN FROM SC_LOG.INT_UDM_TMS.T_TD_GBL_SC_TMS_TRANSPORT_TRACKING QUALIFY RN=1)
